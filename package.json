{
  "name": "allcanaccess",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.49.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "serve": "^14.2.4",
    "wait-on": "^8.0.1"
  },
  "proxy": "http://localhost:4000",
  "scripts": {
    "start": "cross-env PORT=3010 HOST=0.0.0.0 react-scripts start",
    "server": "node --max-http-header-size=262144 server/index.js",
    "db:migrate": "node server/db/migrate.js",
    "dev": "concurrently -k \"npm run start\" \"wait-on tcp:3010 && cross-env NODE_ENV=development npm run server\"",
    "build": "react-scripts build",
    "start:prod": "cross-env NODE_ENV=production PORT=3010 CLIENT_ORIGIN=http://localhost:3010 node --max-http-header-size=262144 server/index.js",
    "build:prod": "npm run build && npm run start:prod",
    "test": "react-scripts test",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test e2e/a11y.spec.js",
    "verify": "npm run build",
    "verify:e2e": "npm run build && playwright test",
    "serve:prod": "serve -s build -l 4173",
    "eject": "react-scripts eject"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
