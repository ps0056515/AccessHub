{
  "name": "allcanaccess",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "google-auth-library": "^9.15.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.49.1",
    "better-sqlite3": "^11.8.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "serve": "^14.2.4"
  },
  "scripts": {
    "start": "cross-env PORT=3010 HOST=0.0.0.0 DANGEROUSLY_DISABLE_HOST_CHECK=true react-scripts start",
    "server": "cross-env API_PORT=3001 node server/index.js",
    "dev": "concurrently -n api,web -c blue,green \"cross-env API_PORT=3001 npm run server\" \"npm start\"",
    "db:migrate": "node server/db/migrate.js",
    "db:import-sqlite": "node server/db/import-sqlite.js",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test e2e/a11y.spec.js",
    "verify": "npm run build",
    "verify:e2e": "npm run build && playwright test",
    "serve:prod": "serve -s build -l 3010",
    "eject": "react-scripts eject"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
