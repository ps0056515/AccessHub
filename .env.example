# API server
PORT=3001
JWT_SECRET=change-me-in-production
JWT_TTL=7d
DATABASE_PATH=./data/accesshub.db

# Google OAuth (create at https://console.cloud.google.com/apis/credentials)
# Web client — add http://localhost:3000 as an authorized JavaScript origin
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Comma-separated emails allowed to access /admin
ADMIN_EMAILS=you@example.com

# Frontend (optional — dev server loads client ID from /api/auth/config)
# REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# REACT_APP_API_URL=http://localhost:3001
