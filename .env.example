# PostgreSQL (required)
DATABASE_URL=postgresql://postgres:TestAdmin@103.182.211.219:5432/accesshub

# API port (React dev uses 3010 via .env.development)
API_PORT=3015

JWT_SECRET=change-me-in-production
JWT_TTL=7d

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Web client — add http://localhost:3010 as an authorized JavaScript origin
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated admin emails (can access /admin dashboard)
ADMIN_EMAILS=pradeep.srinivasan@gmail.com

# Same value as GOOGLE_CLIENT_ID — lets React read it without calling the API
REACT_APP_GOOGLE_CLIENT_ID=
# REACT_APP_API_URL=http://localhost:3015

# Password reset — link base (must match where users open the app)
APP_URL=http://localhost:3010
PASSWORD_RESET_TTL_HOURS=1

# Optional SMTP (if unset, reset links are logged to the API console in dev)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=AccessHub <noreply@yourdomain.com>