# PostgreSQL
DATABASE_URL=postgresql://accesshub:accesshub@localhost:5432/accesshub

# API server (Express)
PORT=4000
NODE_ENV=development

# CORS (comma-separated). Dev: React on 3000. Prod on 4000: http://localhost:4000
CLIENT_ORIGIN=http://localhost:3000,http://localhost:4000

# Auth — change in production
JWT_SECRET=replace-with-a-long-random-secret
COOKIE_NAME=accesshub_token

# Set true only behind HTTPS (leave false for http://localhost)
# COOKIE_SECURE=true

# Optional: explicit API URL for React (dev uses package.json proxy)
# REACT_APP_API_URL=http://localhost:4000

# Max HTTP header size in bytes (localhost cookie bloat)
# MAX_HTTP_HEADER_SIZE=262144
